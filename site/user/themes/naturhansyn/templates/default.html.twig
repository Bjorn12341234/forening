{% extends 'partials/base.html.twig' %}

{% block content %}
<div class="page-header">
  <div class="container">
    <h1>{{ page.title }}</h1>
    {% if page.header.subtitle %}
      <p>{{ page.header.subtitle }}</p>
    {% endif %}
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    <div class="content-block fade-in">
      {{ page.content|raw }}
    </div>
  </div>
</section>
{% endblock %}
