<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if page.title %}{{ page.title }} — {% endif %}{{ site.title|default('NaturHänsyn') }}</title>
  <meta name="description" content="{{ page.summary ? page.summary|striptags|truncate(160) : site.metadata.description|default('Föreningen NaturHänsyn arbetar för att skydda värdefull natur i Sverige.') }}">

  {# Open Graph #}
  <meta property="og:title" content="{{ page.title|default(site.title) }}">
  <meta property="og:description" content="{{ page.summary ? page.summary|striptags|truncate(160) : site.metadata.description|default('') }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="sv_SE">

  {# Fonts & Styles #}
  <link rel="stylesheet" href="{{ url('theme://css/fonts.css') }}">
  <link rel="stylesheet" href="{{ url('theme://css/main.css') }}">

  {# Favicon #}
  <link rel="icon" type="image/png" href="{{ url('theme://images/logo.png') }}">

  {% block head %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">

  {% include 'partials/header.html.twig' %}

  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {% include 'partials/footer.html.twig' %}

  <script src="{{ url('theme://js/main.js') }}" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
