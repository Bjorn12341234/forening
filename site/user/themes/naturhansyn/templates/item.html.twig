{% extends 'partials/base.html.twig' %}
{% import 'partials/macros.html.twig' as macros %}

{% block structured_data %}
{% if page.parent.slug == 'event' and page.date %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "{{ page.title }}",
  "startDate": "{{ page.date|date('Y-m-d') }}",
  "url": "{{ page.url(true) }}",
  "organizer": {
    "@type": "NGO",
    "name": "Föreningen NaturHänsyn",
    "url": "{{ base_url_absolute }}"
  },
  "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode"
}
</script>
{% endif %}
{% endblock %}

{% block content %}
<div class="page-header">
  <div class="container">
    <h1>{{ page.title }}</h1>
    {% if page.date %}
      <p><time datetime="{{ page.date|date('Y-m-d') }}">{{ macros.swedish_date(page.date) }}</time></p>
    {% endif %}
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    {% if page.header.image %}
    <figure class="content-image fade-in">
      <img src="{{ page.header.image }}" alt="{{ page.title }}" loading="lazy">
      {% if page.header.image_credit %}
        <figcaption>Foto: {{ page.header.image_credit }}</figcaption>
      {% endif %}
    </figure>
    {% endif %}

    <div class="content-block fade-in">
      {{ page.content|raw }}
    </div>

    <div style="margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-md);">
      <a href="{{ page.parent.url }}">&larr; Tillbaka till {{ page.parent.title }}</a>
      <a href="/medlemskap" class="btn btn--primary btn--sm">Bli medlem</a>
    </div>
  </div>
</section>
{% endblock %}
