{% extends 'partials/base.html.twig' %}
{% import 'partials/macros.html.twig' as macros %}

{% block content %}
<div class="page-header">
  <div class="container">
    <h1>{{ page.title }}</h1>
    {% if page.date %}
      <p><time datetime="{{ page.date|date('Y-m-d') }}">{{ macros.swedish_date(page.date) }}</time></p>
    {% endif %}
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    {% if page.header.image %}
    <figure class="content-image fade-in">
      <img src="{{ page.header.image }}" alt="{{ page.title }}" loading="lazy">
      {% if page.header.image_credit %}
        <figcaption>Foto: {{ page.header.image_credit }}</figcaption>
      {% endif %}
    </figure>
    {% endif %}

    <div class="content-block fade-in">
      {{ page.content|raw }}
    </div>

    <p style="margin-top: var(--space-2xl);">
      <a href="{{ page.parent.url }}">&larr; Tillbaka</a>
    </p>
  </div>
</section>
{% endblock %}
