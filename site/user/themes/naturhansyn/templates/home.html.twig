{% extends 'partials/base.html.twig' %}

{% block body_class %}page-home{% endblock %}

{% block preload %}
<link rel="preload" href="{{ url('theme://images/hero/norrbotten.jfif') }}" as="image">
{% endblock %}

{% block content %}
{# Hero Section #}
<section class="hero">
  <div class="hero__bg">
    <img src="{{ url('theme://images/hero/norrbotten.jfif') }}" alt="Skogslandskap i Norrbotten" loading="eager" fetchpriority="high" width="1024" height="1025">
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">NaturHänsyn</h1>
    <p class="hero__subtitle">– för allas vår skull!</p>
    <p class="hero__text">{{ page.header.hero_text|default('Föreningen NaturHänsyn har som syfte att arbeta för att såväl markägare som skogsbolag och myndigheter tar sitt ansvar och visar Hänsyn till Naturen!') }}</p>
    <div class="hero__actions">
      <a href="/medlemskap" class="btn btn--cta">Bli medlem</a>
      <a href="/om-foereningen" class="btn btn--outline">Läs mer om oss</a>
    </div>
  </div>
  <style>
  .floating-badge{position:absolute;top:24%;left:12%;display:inline-flex;align-items:center;gap:.4rem;background:rgba(220,40,40,.85);color:#fff;padding:.5rem 1.1rem .5rem .8rem;border-radius:2rem;text-decoration:none;font-family:var(--font-body);font-weight:700;font-size:.85rem;letter-spacing:.03em;box-shadow:0 0 14px rgba(220,40,40,.6),0 0 35px rgba(220,40,40,.3),0 2px 8px rgba(0,0,0,.2);animation:badge-float 3s ease-in-out infinite;cursor:pointer;transform:rotate(-6deg);z-index:5}
  .floating-badge:hover{color:#fff;box-shadow:0 0 22px rgba(220,40,40,.8),0 0 50px rgba(220,40,40,.4),0 4px 12px rgba(0,0,0,.25);transform:rotate(-2deg) scale(1.1)}
  .floating-badge__dot{width:8px;height:8px;border-radius:50%;background:#fff;box-shadow:0 0 6px rgba(255,255,255,.9);animation:dot-pulse 1.2s ease-in-out infinite;flex-shrink:0}
  @keyframes badge-float{0%,100%{transform:rotate(-6deg) translateY(0) translateX(0)}33%{transform:rotate(-4deg) translateY(-6px) translateX(3px)}66%{transform:rotate(-7deg) translateY(2px) translateX(-2px)}}
  @keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.6)}}
  @media (max-width:767px){.floating-badge{top:18%;left:5%;font-size:.75rem;padding:.4rem .9rem .4rem .7rem}}
  </style>
  <a href="/nyheter/arsmote-2026" class="floating-badge" data-expires="2026-03-31">
    <span class="floating-badge__dot"></span>
    <span class="floating-badge__text">Nyhet!</span>
  </a>
  <div class="hero__scroll" aria-hidden="true">
    <span>Scrolla</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

{# Mission Statement #}
<section class="section mission">
  <div class="mission__logo" aria-hidden="true"></div>
  <div class="container container--narrow text-center fade-in">
    {{ page.content|raw }}
  </div>
</section>

{# Four Pillars #}
<section class="section section--alt">
  <div class="container">
    <h2 class="text-center mb-3xl fade-in">Vad gör vi?</h2>
    <div class="pillars stagger-children">
      {% for pillar in page.header.pillars %}
      <div class="pillar fade-in">
        <div class="pillar__icon">{{ pillar.icon|raw }}</div>
        <h3 class="pillar__title">{{ pillar.title }}</h3>
        <p class="pillar__text">{{ pillar.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# CTA Banner with Three.js Aurora #}
<section class="section section--dark cta-banner cta-banner--aurora text-center" id="cta-aurora">
  <canvas id="aurora-canvas" class="cta-banner__canvas" aria-hidden="true"></canvas>
  <div class="container container--narrow fade-in">
    <h2>Vill du göra skillnad?</h2>
    <p class="mb-2xl">Oavsett om du vill stötta oss som passiv medlem eller aktivt delta i vårt arbete — varje medlem räknas!</p>
    <a href="/medlemskap" class="btn btn--cta">Bli medlem — 100 kr/år</a>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script type="module" src="{{ url('theme://js/scene.min.js') }}"></script>
<script>
document.querySelectorAll('.floating-badge[data-expires]').forEach(function(el) {
  var expires = el.getAttribute('data-expires');
  if (expires && new Date(expires + 'T23:59:59') < new Date()) {
    el.remove();
  }
});
</script>
{% endblock %}
