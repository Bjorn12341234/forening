{% extends 'partials/base.html.twig' %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "{{ page.title }}",
  "url": "{{ page.url(true) }}",
  "mainEntity": {
    "@type": "NGO",
    "name": "Föreningen NaturHänsyn",
    "email": "naturhansyn@gmail.com",
    "url": "{{ base_url_absolute }}"
  }
}
</script>
{% endblock %}

{% block content %}
<div class="page-header">
  <div class="container">
    <h1>{{ page.title }}</h1>
    {% if page.header.subtitle %}
      <p>{{ page.header.subtitle }}</p>
    {% endif %}
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    {% if page.header.contact_image %}
    <figure class="content-image fade-in">
      <img src="{{ page.header.contact_image }}" alt="Kontakta oss" loading="lazy">
    </figure>
    {% endif %}

    <div class="content-block mb-2xl fade-in">
      {{ page.content|raw }}
    </div>

    {# Contact Form #}
    <div class="content-block mb-2xl fade-in">
      <h2>Skicka ett meddelande</h2>
      {% include "forms/form.html.twig" %}
    </div>

    <div class="content-block fade-in">
      <h2>Kontaktuppgifter</h2>
      <p>
        <strong>E-post:</strong>
        <a href="mailto:naturhansyn@gmail.com">naturhansyn@gmail.com</a>
      </p>
      <p>
        <strong>Facebook:</strong>
        <a href="https://www.facebook.com/profile.php?id=61558332027547" target="_blank" rel="noopener">Föreningen NaturHänsyn på Facebook</a>
      </p>
      <p style="margin-top: var(--space-xl); color: var(--color-text-muted); font-style: italic;">
        Vi återkopplar så fort vi har möjlighet! /Styrelsen
      </p>
    </div>

    <div class="content-block fade-in" style="margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid var(--color-border);">
      <p>Vill du stötta vårt arbete? <a href="/medlemskap"><strong>Bli medlem</strong></a> — varje medlem gör skillnad! Läs mer <a href="/om-foereningen">om föreningen</a>.</p>
    </div>
  </div>
</section>
{% endblock %}
